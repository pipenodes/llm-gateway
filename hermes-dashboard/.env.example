# ── Auth mode ──────────────────────────────────────────────────────────────────
# Leave empty for OSS admin-key mode (no registration required).
# Set to the auth service URL for cloud/enterprise JWT authentication.
# Example: https://auth.pipenodes.io
VITE_AUTH_URL=

# ── Gateway API ────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8080
