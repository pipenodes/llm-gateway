{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Cursor Quality Report",
  "type": "object",
  "required": [
    "date",
    "template",
    "version",
    "usesTailwindV4",
    "usesMUI",
    "usesCustomCSS",
    "usesMUIProComponents",
    "newDependencies",
    "dependenciesJustified",
    "notes"
  ],
  "properties": {
    "date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "template": {
      "type": "string",
      "enum": [
        "react-vite-mui",
        "react-vite-tailwind",
        "unknown"
      ]
    },
    "version": {
      "type": "string",
      "enum": [
        "free",
        "pro",
        "unknown"
      ]
    },
    "usesTailwindV4": {
      "type": "boolean"
    },
    "usesMUI": {
      "type": "boolean"
    },
    "usesCustomCSS": {
      "type": "boolean"
    },
    "usesMUIProComponents": {
      "type": "boolean"
    },
    "newDependencies": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "dependenciesJustified": {
      "type": "boolean"
    },
    "notes": {
      "type": "string"
    },
    "generatedAt": {
      "type": "string"
    },
    "generatedBy": {
      "type": "string"
    }
  },
  "additionalProperties": true
}
